{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "staging"
      }
    },
    "staging": {
      "extends": "preview",
      "channel": "staging",
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "staging",
        "EXPO_PUBLIC_SUPABASE_URL": "https://owaxxhwbamgzymdqbqhz.supabase.co",
        "EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_F1CpWQwp12n9EQtgxXFHwg_xcKr3Eeu",
        "EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL": "https://owaxxhwbamgzymdqbqhz.supabase.co/functions/v1",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_51SlCAo8lXfKqafsVMZwZBhVpqnyNmNSsdDjxmfWBy3kRXUJcKLIwDXllFmV3qzAWciyJ8AnQSW87CRDUwOLJNvXj00rQmEUq7Z"
      }
    },
    "production": {
      "channel": "production",
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      }
    }
  },
  "submit": {
